#GOVINFO 
GOVINFO_API_KEY=cYC1daejZ97nLjhC54ABcOZAa0iRsfCgudINtz7Y
GOVINFO_BASE_URL=https://api.govinfo.gov
# App
# onehaven_decision_engine/.env.example

APP_ENV=dev

# CORS (comma-separated or "*")
CORS_ALLOW_ORIGINS=*

# Supported market sync / scalable regional coverage
MARKET_SYNC_DAILY_MARKET_LIMIT=6
MARKET_SYNC_DEFAULT_LIMIT_PER_MARKET=250
MARKET_SYNC_DAILY_TIER_FILTER=all
MARKET_CATALOG_BACKEND=static
MARKET_SYNC_ENABLE_STATEWIDE_EXPANSION=0

# ---- Auth (cookie JWT) ----
# IMPORTANT: set a real random value for JWT_SECRET in any environment beyond local dev.
JWT_SECRET=onehaven-local-dev-secret
JWT_EXP_MINUTES=10080
JWT_COOKIE_NAME=onehaven_jwt
JWT_COOKIE_SECURE=0
JWT_COOKIE_SAMESITE=lax

# Local bypass headers only if APP_ENV=local
ALLOW_LOCAL_AUTH_BYPASS=1
DEV_HEADER_ORG_SLUG=X-Org-Slug
DEV_HEADER_USER_EMAIL=X-User-Email
DEV_HEADER_USER_ROLE=X-User-Role
DEV_AUTO_VERIFY_EMAIL=1
GOOGLE_MAPS_API_KEY=your_real_key_here

# API keys (optional)
AUTH_MODE=jwt
DEV_AUTO_PROVISION=1
ENABLE_API_KEYS=0
API_KEY_PEPPER=dev-pepper-change-me
API_KEY_PREFIX_LEN=10



# Plans
DEFAULT_PLAN_CODE=free

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_QUEUE=celery

# Agents
AGENTS_MAX_RUNS_PER_PROPERTY_PER_HOUR=3
AGENTS_MAX_RETRIES=3
AGENTS_RUN_TIMEOUT_SECONDS=120
TRACE_MIRROR_TO_MESSAGES=0

JURISDICTION_AUTOMATION_ENABLED=1
JURISDICTION_NOTIFICATION_ENABLED=1
JURISDICTION_CRITICAL_STALE_LOCKOUT_ENABLED=1

JURISDICTION_REFRESH_SCHEDULE_MINUTES=720
JURISDICTION_DISCOVERY_RETRY_SCHEDULE_MINUTES=1440
JURISDICTION_VALIDATION_RETRY_SCHEDULE_MINUTES=360
JURISDICTION_RECOMPUTE_SCHEDULE_MINUTES=720
JURISDICTION_HEALTH_SCHEDULE_MINUTES=360

JURISDICTION_SLA_DEFAULT_HOURS=720
JURISDICTION_SLA_AUTHORITATIVE_HOURS=504
JURISDICTION_SLA_CRITICAL_AUTHORITATIVE_HOURS=336
JURISDICTION_SLA_PROGRAM_OVERLAY_HOURS=336
JURISDICTION_SLA_DISCOVERY_RETRY_HOURS=24
JURISDICTION_SLA_VALIDATION_RETRY_HOURS=12